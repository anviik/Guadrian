# Copy to .env. WITHOUT any key Guardian runs in mock mode (scripted worker +
# heuristic judge) — the full demo works with zero keys. Add ONE key to switch
# the worker and judge to a real model (auto-detected, OpenAI first):

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini            # optional override

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# Force a mode regardless of keys: mock | llm | auto (default)
# GUARDIAN_AGENTS=auto
